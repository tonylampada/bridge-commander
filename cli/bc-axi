async function cmdDrain() {
  // feed.drain — at-least-once: the server serves everything past each
  // lieutenant's committed ack cursor and drain never advances it. After
  // HANDLING the items, run `bc-axi ack <seq>` with the highest seq handled;
  // until then every drain re-offers the same items (dedupe by seq).
  // Default output is agent-ergonomic (card context + next-action hint per
  // item); --json prints the raw QueueItems, one JSON line each.
  const q = opts.lieutenant ? '?lieutenant=' + encodeURIComponent(opts.lieutenant) : '';
  const r = await request('GET', '/api/feed' + q);
  if (opts.json) { for (const it of r.items) console.log(JSON.stringify(it)); return; }
  if (!r.items.length) { console.log('queue empty — nothing pending.'); return; }
  let cards = [];
  try { cards = (await request('GET', '/api/board')).cards || []; } catch (e) { /* context is best-effort */ }
  const cardBit = (id) => {
    const c = cards.find((x) => x.id === id);
    return 'card ' + id + (c ? ' "' + c.title + '" [' + c.column + ']' : ' (not on the board — archived?)');
  };
  const indent = (t) => '    ' + String(t).replace(/\n/g, '\n    ');
  console.log(r.items.length + ' pending item(s):\n');
  let max = 0;
  for (const it of r.items) {
    if (it.seq > max) max = it.seq;
    let head = it.kind + (it.card ? ' — ' + cardBit(it.card) : '');
    let hint = '';
    const cm = /^card:(.+)$/.exec(it.target || '');
    if (it.kind === 'message' && cm) {
      head = 'captain message on ' + cardBit(cm[1]);
      hint = 'reply on the thread: bc-axi say ' + it.target + ' --text-file <f|->';
    } else if (it.kind === 'message') {
      head = 'captain message (your main chat)';
      hint = 'reply: bc-axi say ' + (it.target || 'lieutenant:' + it.lieutenant) + ' --text-file <f|->';
    } else if (it.kind === 'start-order') {
      head = 'START ORDER — ' + cardBit(it.card);
      hint = 'the captain ordered this card started: read it (bc-axi card show ' + it.card + '), brief the worker, then: bc-axi card start ' + it.card + ' [--brief-file <f>]';
    } else if (it.kind === 'rework-order') {
      head = 'REWORK ORDER — ' + cardBit(it.card);
      hint = 'the captain sent this back: steer the live worker (short line into its session) or restart one with an updated brief (bc-axi card start ' + it.card + ' --brief-file <f>); when reworked, rewrite the body and hand off: bc-axi card move ' + it.card + ' review';
    } else if (it.kind === 'worker-signal') {
      head = 'worker milestone — ' + cardBit(it.card);
      hint = 'note it; act only if it changes your plan';
    } else if (it.kind === 'worker-done') {
      head = 'WORKER DONE — ' + cardBit(it.card);
      hint = 'verify the work in its worktree (read the diff/branch, not just the outcome text), rewrite the card body to current state (bc-axi card patch ' + it.card + ' --body-file <f|->), then hand off: bc-axi card move ' + it.card + ' review';
    } else if (it.kind === 'worker-died') {
      head = 'WORKER DIED — ' + cardBit(it.card);
      hint = 'the worker session died without done: resume it (bc-axi card start ' + it.card + ' --resume) or move the card back to backlog';
    } else if (it.kind === 'pr-merged') {
      head = 'PR MERGED — ' + cardBit(it.card);
      hint = 'the server archived the card and released the worktree; nothing to do beyond noting it';
    } else if (it.kind === 'pr-closed') {
      head = 'PR CLOSED (unmerged) — ' + cardBit(it.card);
      hint = 'decide: rework and reopen, or archive the card (killed)';
    } else if (it.kind === 'card-created') {
      head = 'new card for you — ' + cardBit(it.card);
      hint = 'read it: bc-axi card show ' + it.card;
    } else if (it.kind === 'card-moved') {
      head = 'captain moved ' + cardBit(it.card) + ': ' + it.from + ' -> ' + it.to;
    }
    console.log('#' + it.seq + '  ' + head);
    if (it.text) console.log(indent(it.text));
    if (hint) console.log('    -> ' + hint);
    console.log('');
  }
  console.log('handle EVERY item above, then commit: bc-axi ack ' + max + '   (only ack after handling; unacked items re-offer)');
}

async function cmdAck() {
  const seq = parseInt(positional[0], 10);
  if (!Number.isInteger(seq) || seq < 0) die('usage: bc-axi ack <seq>   (highest queue seq you have HANDLED)');
  const r = await request('POST', '/api/feed/ack', { seq });
  console.log('acked ' + seq + ' (lieutenant=' + r.lieutenant + ' committed=' + r.ack + ')');
}

// ---------- status ----------
function fmtStatus(s) {
  const w = s && s.worker ? s.worker : { id: null, state: 'absent' };
  return 'worker=' + w.state + (w.id ? '(' + w.id + ')' : '') + ' owed=' + !!(s && s.owed) + ' unread=' + !!(s && s.unread);
}

async function cmdStatus() {
  // status                                   -> server status
  // status <card-id>                         -> the card's derived status
  // status <card-id> <state> [--worker W] [--ttl secs]  -> status.set (worker lease)
  const id = positional[0];
  if (id) {
    const state = positional[1];
    if (!state) {
      const c = await request('GET', '/api/cards/' + encodeURIComponent(id));
      if (opts.json) return console.log(JSON.stringify(c.status, null, 2));
      return console.log(id + ': ' + fmtStatus(c.status));
    }
    const body = state === 'absent'
      ? { worker: null }
      : { worker: { id: opts.worker, state } };
    if (state !== 'absent' && !opts.worker) die('usage: bc-axi status <card-id> <absent|idle|working|needs-you> [--worker <worker-id>] [--ttl <secs>]\n  (--worker required unless state is absent)');
    if (opts.ttl != null) body.ttl = opts.ttl;
    const r = await request('POST', '/api/cards/' + encodeURIComponent(id) + '/status', body);
    return console.log(id + ': ' + fmtStatus(r.status));
  }
  const st = await serverUp();
  if (!st) { console.log('server: down (workspace ' + WORKSPACE + ', port ' + PORT + ')'); process.exit(1); }
  console.log('server: up  workspace=' + st.workspace + '  cards=' + st.cards + '  lieutenants=' + st.lieutenants +
    '  pending-queue=' + st.queue_pending + '  url=http://localhost:' + PORT + '/');
}

// ---------- config ----------
async function cmdConfig() {
  const sub = positional[0];
  if (sub === 'show') {
    let raw; try { raw = fs.readFileSync(CONFIG_FILE, 'utf8').trim(); } catch (e) { raw = '{}'; }
    console.log(raw || '{}');
    return;
  }
  if (sub === 'voices') {
    if (positional.length < 2) die('usage: bc-axi config voices "<name,name,...>"  ("" clears the filter)');
    const names = positional.slice(1).join(' ').split(',').map((s) => s.trim()).filter(Boolean);
    let cfg = {};
    try { cfg = JSON.parse(fs.readFileSync(CONFIG_FILE, 'utf8')); } catch (e) {}
    if (!cfg || typeof cfg !== 'object' || Array.isArray(cfg)) cfg = {};
    if (names.length) cfg.voices = names; else delete cfg.voices;
    fs.mkdirSync(STATE_DIR, { recursive: true });
    fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2) + '\n');
    console.log(names.length ? 'voices=' + names.join(',') : 'voices cleared');
    return;
  }
  die('usage: bc-axi config <show | voices "<name,name,...>">');
}

