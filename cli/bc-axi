#!/usr/bin/env node
// bc-axi — agent CLI for the bridge-command board. Node built-ins only, zero deps.
// Run with no args for full usage. Message/body/charter text always goes via
// --text-file, --body-file, --charter-file, or stdin — never interpolated into a
// shell command.
//
// Workspace resolution (no --board, no global state): --workspace wins; else walk
// up from cwd to the nearest directory containing .bridge-command/; `open` may
// bootstrap a fresh workspace in cwd. The server port comes from the workspace's
// .bridge-command/config.json (default 4780); --port overrides.
'use strict';

const http = require('http');
const fs = require('fs');
const path = require('path');
const { spawn } = require('child_process');

const SELF_DIR = path.dirname(fs.realpathSync(process.argv[1]));
const SERVER_JS = path.join(SELF_DIR, '..', 'server', 'server.js');
const DEFAULT_PORT = 4780;

function die(msg) { console.error(msg); process.exit(1); }

// ---------- args ----------
const argv = process.argv.slice(2);
let cmd = argv.shift();
const opts = {
  workspace: '', port: 0, host: '',
  textFile: null, bodyFile: null, charterFile: null,
  title: null, column: null, id: null, type: null, owner: null, lieutenant: null,
  name: null, color: null,
  level: null, kind: null, actor: null, reason: null, note: null, attrs: [], labels: [], json: false,
  worker: null, ttl: null,
};
const positional = [];
for (let i = 0; i < argv.length; i++) {
  const a = argv[i];
  if (a === '--workspace') opts.workspace = argv[++i];
  else if (a === '--port') opts.port = parseInt(argv[++i], 10);
  else if (a === '--host') opts.host = argv[++i];
  else if (a === '--text-file') opts.textFile = argv[++i];
  else if (a === '--body-file') opts.bodyFile = argv[++i];
  else if (a === '--charter-file') opts.charterFile = argv[++i];
  else if (a === '--title') opts.title = argv[++i];
  else if (a === '--column') opts.column = argv[++i];
  else if (a === '--id') opts.id = argv[++i];
  else if (a === '--type') opts.type = argv[++i];
  else if (a === '--owner') opts.owner = argv[++i];
  else if (a === '--lieutenant') opts.lieutenant = argv[++i];
  else if (a === '--name') opts.name = argv[++i];
  else if (a === '--color') opts.color = argv[++i];
  else if (a === '--level') opts.level = parseInt(argv[++i], 10);
  else if (a === '--kind') opts.kind = argv[++i];
  else if (a === '--actor') opts.actor = argv[++i];
  else if (a === '--reason') opts.reason = argv[++i];
  else if (a === '--note') opts.note = argv[++i];
  else if (a === '--worker') opts.worker = argv[++i];
  else if (a === '--ttl') opts.ttl = parseFloat(argv[++i]);
  else if (a === '--attr') opts.attrs.push(argv[++i]);
  else if (a === '--label') opts.labels.push(argv[++i]);
  else if (a === '--json') opts.json = true;
  else positional.push(a);
}
// Two-word verbs mirror the DNA operation names: `card create`, `lieutenant list`, …
if ((cmd === 'card' || cmd === 'lieutenant') && positional.length) cmd = cmd + ' ' + positional.shift();

// ---------- workspace resolution ----------
function findWorkspace(start) {
  let dir = path.resolve(start);
  for (;;) {
    if (fs.existsSync(path.join(dir, '.bridge-command'))) return dir;
    const up = path.dirname(dir);
    if (up === dir) return null;
    dir = up;
  }
}
const WORKSPACE = opts.workspace
  ? path.resolve(opts.workspace)
  : (cmd === 'open' ? (findWorkspace(process.cwd()) || process.cwd()) : findWorkspace(process.cwd()));
if (!WORKSPACE) die('no workspace found: no .bridge-command/ from cwd upward (run `bc-axi open` to start one here, or pass --workspace)');
const STATE_DIR = path.join(WORKSPACE, '.bridge-command');
const CONFIG_FILE = path.join(STATE_DIR, 'config.json');
const PID_FILE = path.join(STATE_DIR, 'server.pid');

function readConfig() {
  try {
    const c = JSON.parse(fs.readFileSync(CONFIG_FILE, 'utf8'));
    if (c && typeof c === 'object' && !Array.isArray(c)) return c;
  } catch (e) {}
  return {};
}
const PORT = opts.port || (Number.isInteger(readConfig().port) && readConfig().port > 0 ? readConfig().port : DEFAULT_PORT);
const BASE = 'http://127.0.0.1:' + PORT;

// ---------- helpers ----------
function request(method, urlPath, body, timeoutMs) {
  return new Promise((resolve, reject) => {
    const data = body == null ? null : JSON.stringify(body);
    const req = http.request(BASE + urlPath, {
      method,
      headers: data ? { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) } : {},
      timeout: timeoutMs || 10000,
    }, (res) => {
      let out = '';
      res.on('data', (c) => (out += c));
      res.on('end', () => {
        let parsed; try { parsed = JSON.parse(out); } catch (e) { parsed = out; }
        if (res.statusCode >= 400) reject(new Error('HTTP ' + res.statusCode + ': ' + out));
        else resolve(parsed);
      });
    });
    req.on('timeout', () => { req.destroy(new Error('timeout')); });
    req.on('error', reject);
    if (data) req.write(data);
    req.end();
  });
}
async function serverUp() {
  try { return await request('GET', '/api/status', null, 1500); } catch (e) { return null; }
}
function readInput(fileArg) {
  const src = fileArg && fileArg !== '-' ? fileArg : 0; // fd 0 = stdin
  return fs.readFileSync(src, 'utf8');
}
function parseAttrs(list) {
  const out = {};
  for (const kv of list) {
    const i = kv.indexOf('=');
    if (i <= 0) die('bad --attr (want key=value): ' + kv);
    const v = kv.slice(i + 1);
    out[kv.slice(0, i)] = v === '' ? null : v; // key= deletes the attribute
  }
  return out;
}
const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
function hhmm(iso) { try { return new Date(iso).toISOString().slice(5, 16).replace('T', ' '); } catch (e) { return ''; } }
const TARGET_RE = /^(lieutenant:.+|card:.+)$/;

// ---------- server ----------
async function cmdOpen() {
  let st = await serverUp();
  if (!st) {
    const args = [SERVER_JS, WORKSPACE, '--port', String(PORT)];
    if (opts.host) args.push('--host', opts.host); // else server resolves: config.json "host" > 127.0.0.1
    const child = spawn(process.execPath, args, {
      detached: true, stdio: 'ignore',
    });
    child.unref();
    for (let i = 0; i < 20 && !st; i++) { await sleep(150); st = await serverUp(); }
    if (!st) die('failed to start server on port ' + PORT);
    console.log('http://localhost:' + PORT + '/');
    console.log('started workspace=' + st.workspace + ' cards=' + st.cards);
  } else {
    console.log('http://localhost:' + PORT + '/');
    console.log('already running workspace=' + st.workspace + ' cards=' + st.cards);
  }
}

async function cmdStop() {
  let pid = null;
  try { pid = parseInt(fs.readFileSync(PID_FILE, 'utf8'), 10); } catch (e) {}
  if (!pid) { const st = await serverUp(); pid = st && st.pid; }
  if (!pid) die('no server found for workspace ' + WORKSPACE);
  try { process.kill(pid, 'SIGTERM'); } catch (e) { die('failed to stop pid ' + pid + ': ' + e.message); }
  console.log('stopped pid=' + pid);
}

// ---------- lieutenants ----------
async function cmdLtCreate() {
  if (!opts.name) die('usage: bc-axi lieutenant create --name N [--id id] [--color #rrggbb] [--charter-file f|-]');
  const body = { name: opts.name };
  if (opts.id) body.id = opts.id;
  if (opts.color) body.color = opts.color;
  if (opts.charterFile) body.charter = readInput(opts.charterFile);
  if (opts.actor) body.actor = opts.actor;
  const r = await request('POST', '/api/lieutenants', body);
  console.log('lieutenant ' + r.lieutenant.id + ' created (' + r.lieutenant.color + ')');
}

async function cmdLtList() {
  const r = await request('GET', '/api/lieutenants');
  if (opts.json) return console.log(JSON.stringify(r.lieutenants, null, 2));
  for (const l of r.lieutenants) {
    const charter = (l.charter || '').split('\n')[0].slice(0, 80);
    console.log(l.id + '\t' + l.name + '\t' + l.color + (charter ? '\t' + charter : ''));
  }
}

// ---------- reads ----------
async function cmdBoard() {
  const b = await request('GET', '/api/board');
  if (opts.json) return console.log(JSON.stringify(b, null, 2));
  console.log(b.title + (b.subtitle ? ' — ' + b.subtitle : ''));
  if (b.lieutenants.length) {
    console.log('\nlieutenants: ' + b.lieutenants.map((l) => l.id).join(', '));
  }
  for (const col of b.columns) {
    const cards = b.cards.filter((c) => c.column === col.id);
    console.log('\n' + col.title + ' (' + cards.length + ')');
    for (const c of cards) {
      const at = c.attributes || {};
      const st = c.status || {};
      const w = st.worker && st.worker.state !== 'absent' ? st.worker.state : '';
      const prs = Array.isArray(at.prs) && at.prs.length ? 'PRs:' + at.prs.map((p) => p.state).join(',') : '';
      const extras = [c.type, c.owner, (c.labels || []).join(','), prs,
        w, c.pendingOrder ? c.pendingOrder.kind : '', st.owed ? 'owed' : '', st.unread ? 'unread' : '']
        .filter(Boolean).join(' | ');
      console.log('  ' + c.id + '  ' + c.title + (extras ? '  [' + extras + ']' : ''));
    }
  }
}

async function cmdShow() {
  const id = positional[0] || die('usage: bc-axi card show <card-id>');
  const c = await request('GET', '/api/cards/' + encodeURIComponent(id));
  if (opts.json) return console.log(JSON.stringify(c, null, 2));
  console.log('# ' + c.title + '  (id=' + c.id + ', type=' + c.type + ', owner=' + c.owner + ', column=' + c.column + ')');
  console.log('status: ' + fmtStatus(c.status));
  if (c.pendingOrder) console.log('pending order: ' + c.pendingOrder.kind + ' (seq ' + c.pendingOrder.seq + ')');
  const at = c.attributes || {};
  for (const [k, v] of Object.entries(at)) console.log(k + ': ' + (typeof v === 'object' ? JSON.stringify(v) : v));
  if ((c.labels || []).length) console.log('labels: ' + c.labels.join(', '));
  if (c.body) console.log('\n--- body ---\n' + c.body);
  if ((c.events || []).length) {
    console.log('\n--- events ---');
    for (const e of c.events) console.log(hhmm(e.ts) + '  L' + e.level + ' ' + (e.kind || '-') + '  ' + e.text + '  (' + e.actor + ')');
  }
  if ((c.thread || []).length) {
    console.log('\n--- thread ---');
    for (const m of c.thread) console.log(hhmm(m.ts) + '  ' + m.author + ': ' + m.text.replace(/\n/g, '\n    '));
  }
}

async function cmdThread() {
  const target = positional[0];
  if (!target || !TARGET_RE.test(target)) die('usage: bc-axi thread <lieutenant:ID|card:ID>');
  const b = await request('GET', '/api/board');
  let msgs;
  const lt = /^lieutenant:(.+)$/.exec(target);
  if (lt) {
    const l = b.lieutenants.find((x) => x.id === lt[1]);
    if (!l) die('unknown lieutenant: ' + lt[1]);
    msgs = l.chat || [];
  } else {
    const c = b.cards.find((x) => x.id === target.slice(5));
    if (!c) die('unknown card: ' + target.slice(5));
    msgs = c.thread || [];
  }
  if (opts.json) return console.log(JSON.stringify(msgs, null, 2));
  for (const m of msgs) console.log(hhmm(m.ts) + '  ' + m.author + ': ' + m.text.replace(/\n/g, '\n    '));
}

async function cmdArchived() {
  const r = await request('GET', '/api/archive?limit=' + (parseInt(positional[0], 10) || 20));
  if (opts.json) return console.log(JSON.stringify(r.archive, null, 2));
  for (const rec of r.archive) {
    const why = rec.reason ? rec.reason + (rec.note ? ': ' + rec.note : '') : '';
    console.log(hhmm(rec.ts) + '  ' + rec.card.id + '  ' + rec.card.title + (why ? '  (' + why + ')' : ''));
  }
}

async function cmdKinds() {
  if (!positional.length) { // print the effective map (built-ins merged under registered)
    const r = await request('GET', '/api/kinds');
    if (opts.json) return console.log(JSON.stringify(r, null, 2));
    const reg = r.registered || {};
    for (const [k, v] of Object.entries(r.kinds)) {
      console.log(k + '\t' + v.emoji + '\tL' + v.level + '\t' + (reg[k] ? 'registered' : 'built-in'));
    }
    return;
  }
  const kinds = JSON.parse(readInput(positional[0]));
  const r = await request('PUT', '/api/kinds', kinds);
  console.log('kinds=' + r.kinds + (r.unchanged ? ' (unchanged)' : ''));
}

// ---------- card writes ----------
async function cmdCreate() {
  if (!opts.title || !opts.owner) {
    die('usage: bc-axi card create --title T --owner <lieutenant> [--type plan|implementation|investigation]\n' +
      '                    [--column c] [--id id] [--body-file f|-] [--attr k=v]... [--label l]...');
  }
  const body = {
    title: opts.title, owner: opts.owner, actor: opts.actor || 'agent',
    attributes: parseAttrs(opts.attrs), labels: opts.labels,
  };
  if (opts.type) body.type = opts.type;
  if (opts.id) body.id = opts.id;
  if (opts.column) body.column = opts.column;
  if (opts.bodyFile) body.body = readInput(opts.bodyFile);
  const r = await request('POST', '/api/cards', body);
  console.log('created ' + r.card.id + ' in ' + r.card.column);
}

async function cmdMove() {
  const id = positional[0], column = positional[1];
  if (!id || !column) die('usage: bc-axi card move <card-id> <column> [--actor a] [--level 1|2] [--kind k]\n  (lieutenant moves land only in review — the handoff)');
  const body = { column, actor: opts.actor || 'agent' };
  if (opts.level) body.level = opts.level;
  if (opts.kind) body.kind = opts.kind;
  const r = await request('POST', '/api/cards/' + encodeURIComponent(id) + '/move', body);
  if (r.ordered) console.log('ordered ' + r.ordered + ' for ' + id + ' (queue seq ' + r.seq + ')');
  else console.log(r.unchanged ? 'already in ' + column : 'moved ' + id + ' -> ' + column);
}

async function cmdPatch() {
  const id = positional[0];
  if (!id) die('usage: bc-axi card patch <card-id> [--title T] [--type t] [--owner lt] [--body-file f|-] [--attr k=v]... (--attr k= deletes)');
  const body = {};
  if (opts.title !== null) body.title = opts.title;
  if (opts.type !== null) body.type = opts.type;
  if (opts.owner !== null) body.owner = opts.owner;
  if (opts.bodyFile) body.body = readInput(opts.bodyFile);
  if (opts.attrs.length) body.attributes = parseAttrs(opts.attrs);
  if (!Object.keys(body).length) die('nothing to patch (use --title / --type / --owner / --body-file / --attr)');
  await request('PATCH', '/api/cards/' + encodeURIComponent(id), body);
  console.log('patched ' + id);
}

async function cmdEvent() {
  const id = positional[0];
  if (!id) die('usage: bc-axi event <card-id> [--level 1|2] [--kind K] [--text-file f|-]\n  (text from --text-file or stdin; kind is an open token — a kind in the board\'s\n  kinds map sets the default level and emoji; explicit --level wins, else level 2)');
  const text = readInput(opts.textFile).trim();
  const body = { text, actor: opts.actor || 'agent' };
  if (opts.level) body.level = opts.level;
  if (opts.kind) body.kind = opts.kind;
  const r = await request('POST', '/api/cards/' + encodeURIComponent(id) + '/events', body);
  console.log('event #' + r.event.seq + ' L' + r.event.level + ' -> ' + id);
}

async function cmdNotify() {
  const text = readInput(opts.textFile).trim();
  const body = { text, actor: opts.actor || 'agent', level: opts.level || 1 };
  if (opts.kind) body.kind = opts.kind;
  const r = await request('POST', '/api/events', body);
  console.log('notified #' + r.event.seq);
}

async function cmdArchive() {
  const id = positional[0];
  if (!id) die('usage: bc-axi card archive <card-id> [--reason merged|killed] [--note "..."] [--kind K] [--level 1|2]');
  const body = { actor: opts.actor || 'agent' };
  if (opts.reason) body.reason = opts.reason;
  if (opts.note) body.note = opts.note;
  if (opts.kind) body.kind = opts.kind;
  if (opts.level) body.level = opts.level;
  await request('POST', '/api/cards/' + encodeURIComponent(id) + '/archive', body);
  console.log('archived ' + id);
}

async function cmdRestore() {
  const id = positional[0];
  if (!id) die('usage: bc-axi card restore <card-id> [--actor a] [--note "..."] [--kind K]\n  (resurrection event text from --note or --text-file; default "resurrected")');
  const body = { actor: opts.actor || 'agent' };
  if (opts.textFile) body.text = readInput(opts.textFile).trim();
  else if (opts.note) body.text = opts.note;
  if (opts.kind) body.kind = opts.kind;
  const r = await request('POST', '/api/cards/' + encodeURIComponent(id) + '/restore', body);
  console.log('restored ' + id + ' in ' + r.card.column);
}

// ---------- conversation & delivery ----------
async function cmdSay() {
  const target = positional[0];
  if (!target || !TARGET_RE.test(target)) die('usage: bc-axi say <lieutenant:ID|card:ID> [--actor a] [--text-file f|-]  (text from --text-file or stdin)');
  const text = readInput(opts.textFile);
  const body = { target, text_md: text };
  if (opts.actor) body.author = opts.actor;
  await request('POST', '/api/message', body);
  console.log('said -> ' + target);
}

async function cmdDrain() {
  // feed.drain — at-least-once: the server serves everything past each
  // lieutenant's committed ack cursor and drain never advances it. After
  // HANDLING the items, run `bc-axi ack <seq>` with the highest seq handled;
  // until then every drain re-offers the same items (dedupe by seq).
  const q = opts.lieutenant ? '?lieutenant=' + encodeURIComponent(opts.lieutenant) : '';
  const r = await request('GET', '/api/feed' + q);
  for (const it of r.items) console.log(JSON.stringify(it));
}

async function cmdAck() {
  const seq = parseInt(positional[0], 10);
  if (!Number.isInteger(seq) || seq < 0) die('usage: bc-axi ack <seq>   (highest queue seq you have HANDLED)');
  const r = await request('POST', '/api/feed/ack', { seq });
  console.log('acked ' + seq + ' (lieutenant=' + r.lieutenant + ' committed=' + r.ack + ')');
}

// ---------- status ----------
function fmtStatus(s) {
  const w = s && s.worker ? s.worker : { id: null, state: 'absent' };
  return 'worker=' + w.state + (w.id ? '(' + w.id + ')' : '') + ' owed=' + !!(s && s.owed) + ' unread=' + !!(s && s.unread);
}

async function cmdStatus() {
  // status                                   -> server status
  // status <card-id>                         -> the card's derived status
  // status <card-id> <state> [--worker W] [--ttl secs]  -> status.set (worker lease)
  const id = positional[0];
  if (id) {
    const state = positional[1];
    if (!state) {
      const c = await request('GET', '/api/cards/' + encodeURIComponent(id));
      if (opts.json) return console.log(JSON.stringify(c.status, null, 2));
      return console.log(id + ': ' + fmtStatus(c.status));
    }
    const body = state === 'absent'
      ? { worker: null }
      : { worker: { id: opts.worker, state } };
    if (state !== 'absent' && !opts.worker) die('usage: bc-axi status <card-id> <absent|idle|working|needs-you> [--worker <worker-id>] [--ttl <secs>]\n  (--worker required unless state is absent)');
    if (opts.ttl != null) body.ttl = opts.ttl;
    const r = await request('POST', '/api/cards/' + encodeURIComponent(id) + '/status', body);
    return console.log(id + ': ' + fmtStatus(r.status));
  }
  const st = await serverUp();
  if (!st) { console.log('server: down (workspace ' + WORKSPACE + ', port ' + PORT + ')'); process.exit(1); }
  console.log('server: up  workspace=' + st.workspace + '  cards=' + st.cards + '  lieutenants=' + st.lieutenants +
    '  pending-queue=' + st.queue_pending + '  url=http://localhost:' + PORT + '/');
}

// ---------- config ----------
async function cmdConfig() {
  const sub = positional[0];
  if (sub === 'show') {
    let raw; try { raw = fs.readFileSync(CONFIG_FILE, 'utf8').trim(); } catch (e) { raw = '{}'; }
    console.log(raw || '{}');
    return;
  }
  if (sub === 'voices') {
    if (positional.length < 2) die('usage: bc-axi config voices "<name,name,...>"  ("" clears the filter)');
    const names = positional.slice(1).join(' ').split(',').map((s) => s.trim()).filter(Boolean);
    let cfg = {};
    try { cfg = JSON.parse(fs.readFileSync(CONFIG_FILE, 'utf8')); } catch (e) {}
    if (!cfg || typeof cfg !== 'object' || Array.isArray(cfg)) cfg = {};
    if (names.length) cfg.voices = names; else delete cfg.voices;
    fs.mkdirSync(STATE_DIR, { recursive: true });
    fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2) + '\n');
    console.log(names.length ? 'voices=' + names.join(',') : 'voices cleared');
    return;
  }
  die('usage: bc-axi config <show | voices "<name,name,...>">');
}

const commands = {
  open: cmdOpen, stop: cmdStop, status: cmdStatus, config: cmdConfig,
  board: cmdBoard, thread: cmdThread, archived: cmdArchived, kinds: cmdKinds,
  'lieutenant create': cmdLtCreate, 'lieutenant list': cmdLtList,
  'card create': cmdCreate, 'card move': cmdMove, 'card patch': cmdPatch,
  'card archive': cmdArchive, 'card restore': cmdRestore, 'card show': cmdShow,
  show: cmdShow, // alias for card show
  event: cmdEvent, notify: cmdNotify,
  say: cmdSay, drain: cmdDrain, ack: cmdAck,
};
if (!commands[cmd]) {
  die('bc-axi — agent CLI for the bridge-command board.\n' +
    'Workspace: nearest .bridge-command/ from cwd upward, or --workspace DIR. Port: workspace config.json (default 4780), or --port N.\n' +
    '\nserver:\n' +
    '  open [--host H]                        start the workspace server if needed (idempotent), print URL.\n' +
    '                                         Bootstraps .bridge-command/ in cwd on first run.\n' +
    '  status                                 up/down, cards, lieutenants, pending queue items\n' +
    '  stop                                   stop the workspace server\n' +
    '\nlieutenant:\n' +
    '  lieutenant create --name N [--id id] [--color #rrggbb] [--charter-file f|-]\n' +
    '                                         register a lieutenant (color auto-assigned when omitted)\n' +
    '  lieutenant list [--json]               id, name, color, charter first line\n' +
    '\nread:\n' +
    '  board [--json]                         lane + columns + card one-liners (or full JSON)\n' +
    '  card show <card-id> [--json]           one card: type, owner, attrs, body, events, thread\n' +
    '  thread <lieutenant:ID|card:ID> [--json] print a conversation thread\n' +
    '  archived [n] [--json]                  last n archived cards (default 20)\n' +
    '  kinds [--json]                         print the effective kinds map (built-ins + registered)\n' +
    '\ncard:\n' +
    '  card create --title T --owner <lieutenant> [--type plan|implementation|investigation]\n' +
    '              [--column c] [--id id] [--body-file f|-] [--attr k=v]... [--label l]...\n' +
    '                                         new card (default: implementation, backlog)\n' +
    '  card move <card-id> <column>           lieutenant moves land ONLY in review (the handoff,\n' +
    '                                         level-1 event). Captain drags happen in the UI; a\n' +
    '                                         captain backlog→working / review→backlog drag is an\n' +
    '                                         ORDER (queue item), not a move\n' +
    '  card patch <card-id> [--title T] [--type t] [--owner lt] [--body-file f|-] [--attr k=v]...\n' +
    '                                         update card (k= deletes attr); body = the deliverable,\n' +
    '                                         rewritten to current state before every handoff\n' +
    '  card archive <card-id> [--reason merged|killed] [--note "..."]\n' +
    '                                         kill = archive (append-only file, off the board)\n' +
    '  card restore <card-id> [--note "..."]  resurrect the most recent archived snapshot in full;\n' +
    '                                         appends a loud level-1 event\n' +
    '\nevents & chat:\n' +
    '  event <card-id> [--level 1|2] [--kind K] [--text-file f|-]   append timeline event\n' +
    '                                         level 1 rings the captain; level 2 = timeline only\n' +
    '  notify [--kind K] [--text-file f|-]    board-level notification (no card)\n' +
    '  say <lieutenant:ID|card:ID> [--actor a] [--text-file f|-]\n' +
    '                                         post a chat message; a card thread\'s interlocutor is\n' +
    '                                         the owning lieutenant (lieutenant-main says also notify)\n' +
    '\ndelivery (at-least-once):\n' +
    '  drain [--lieutenant <id>]              print pending QueueItems as JSON lines (captain\n' +
    '    messages, start/rework orders, card-created/moved). Drain never removes: handle the\n' +
    '    items, then ack the highest seq handled; unacked items re-offer (dedupe by seq)\n' +
    '  ack <seq>                              commit that seq\'s lieutenant ack cursor\n' +
    '\nstatus (worker lease; owed/unread are server-derived):\n' +
    '  status <card-id> [--json]              the card\'s derived status: worker/owed/unread\n' +
    '  status <card-id> <state> --worker <id> [--ttl <secs>]\n' +
    '                                         status.set: link worker + state (absent|idle|working|needs-you)\n' +
    '                                         as a lease; past the TTL (default 600s) working/needs-you\n' +
    '                                         decays to idle; "status <card-id> absent" unlinks\n' +
    '\nconfig:\n' +
    '  config show | config voices "a,b"      TTS voice filter for the UI\n' +
    '\nText/body/charter always via --text-file/--body-file/--charter-file or stdin ("-"), never shell-interpolated.');
}
commands[cmd]().catch((e) => die(e.message));
