  const r = await request('POST', '/api/cards/' + encodeURIComponent(id) + '/worker/signal',
    { text, actor: opts.actor || 'worker' });
  console.log('signal #' + r.event.seq + ' -> ' + id);
}

async function cmdWorkerDone() {
  const id = positional[0];
  const outcome = opts.outcome != null ? opts.outcome
    : (opts.textFile ? readInput(opts.textFile).trim() : positional.slice(1).join(' ').trim());
  if (!id || !outcome) {
    die('usage: bc-axi worker done <card-id> --outcome "<what landed>" [or positional text / --text-file f|-]\n' +
      '  Include the full PR URL when one exists (it auto-populates the card\'s prs attribute).');
  }
  const r = await request('POST', '/api/cards/' + encodeURIComponent(id) + '/worker/done',
    { outcome, actor: opts.actor || 'worker' });
  const prs = (r.card.attributes && r.card.attributes.prs) || [];
  console.log('done -> ' + id + ' (owner notified' + (prs.length ? '; prs: ' + prs.map((p) => p.url).join(' ') : '') + ')');
